{
  "name": "ballast",
  "private": true,
  "version": "0.0.0",
  "description": "A USDC vault where Jupiter Lend yield finances NO-contract hedges on tail-risk prediction markets.",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json,yml,yaml}\" --ignore-path .gitignore",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "dev:web": "pnpm --filter @ballast/web dev",
    "dev:orchestrator": "pnpm --filter @ballast/orchestrator dev",
    "build:shared": "pnpm --filter @ballast/shared build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.20.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
