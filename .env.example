# Jupiter API
JUPITER_API_KEY=                          # Sign up at https://developers.jup.ag/portal
JUPITER_API_BASE_URL=https://api.jup.ag

# Solana
SOLANA_RPC_URL=                           # Use a paid RPC for production
SOLANA_CLUSTER=mainnet-beta

# Vault keypair (orchestrator only — never expose to frontend)
VAULT_KEYPAIR_BASE58=                     # base58-encoded secret key

# Database
DATABASE_URL=file:./reflux.sqlite

# Frontend
NEXT_PUBLIC_VAULT_ADDRESS=                # public key of the vault keypair (safe to expose)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4000
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta
NEXT_PUBLIC_RPC_URL=                      # browser-side Solana RPC for the wallet adapter

# Orchestrator
ORCHESTRATOR_PORT=4000
REBALANCE_CRON="0 0 * * *"               # daily at 00:00 UTC
HEDGE_BUDGET_FRACTION=0.5                # fraction of accrued yield allocated to hedges

# Admin auth — required to hit /rebalance/trigger, /claim/*, /admin/* endpoints.
# Generate with: openssl rand -hex 32
ORCHESTRATOR_ADMIN_TOKEN=                 # opaque secret, server-only
